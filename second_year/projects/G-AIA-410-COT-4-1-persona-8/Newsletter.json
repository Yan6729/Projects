    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst currentHour = now.getHours();\nconst currentMinute = now.getMinutes();\n\nconst users = $('Select rows from a table').all().filter(item => {\n  const schedule = item.json.schedule;\n  if (!schedule) return false;\n  const [h, m] = schedule.split(':').map(Number);\n  return currentHour === h && currentMinute === m;\n});\n\nconst articles = $('Merge').all();\n\nreturn users.map(user => ({\n  json: {\n    user: user.json,\n    articles: articles.map(a => a.json),\n    email: user.json.email\n  }\n}));"
      },
