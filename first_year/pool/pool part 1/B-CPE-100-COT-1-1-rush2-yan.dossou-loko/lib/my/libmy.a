#include "../../include/my.h"
#include <stdio.h>
int my_strlen(char const *str)
{
    int b = 0;

    while (str[b] != '\0') {
        b++;
    }
    return (b);
}

char *my_strncpy(char *dest, char const *src, int n)
{
    int i = 0;
    int b = my_strlen(src);

    for (i = 0; src[i] != '\0' && i < n; i++) {
        dest[i] = src[i];
    }
    if (n > b) {
        dest[b] = '\0';
    }
    return (dest);
}
