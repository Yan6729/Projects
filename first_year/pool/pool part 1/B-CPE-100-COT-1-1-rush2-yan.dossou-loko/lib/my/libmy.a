#include <string.h>
#include <stdio.h>
#include "../../include/my.h"
int my_strlen(char *src)
{
    int a;

    a = 0;
    while (src[a] != '\0') {
        a++;
    }
    return (a);
}

char *my_revstr(char *str)
{
    int len;
    int i;
    char *deb;
    char *fin;
    char inter;

    len = my_strlen(str);
    deb = str;
    fin = str;
    for (i = 0; i < len - 1; i++)
        fin++;
    for (i = 0; i < len / 2; i++) {
        inter = *fin;
        *fin = *deb;
        *deb = inter;
        deb++;
        fin--;
    }
    return (str);
}
